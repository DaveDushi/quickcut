---
import Layout from "../layouts/Layout.astro";
import { createDb } from "../db";
import { spaceInvites, spaces } from "../db/schema";
import { eq } from "drizzle-orm";
import { env } from "cloudflare:workers";

const user = Astro.locals.user;
if (user) {
  return Astro.redirect("/dashboard");
}

const error = Astro.url.searchParams.get("error");
const inviteToken = Astro.url.searchParams.get("inviteToken")?.trim() || null;

let invite: {
  email: string;
  spaceName: string;
} | null = null;

if (inviteToken) {
  const db = createDb(env.DB);
  const rows = await db
    .select({
      email: spaceInvites.email,
      status: spaceInvites.status,
      spaceName: spaces.name,
    })
    .from(spaceInvites)
    .innerJoin(spaces, eq(spaceInvites.spaceId, spaces.id))
    .where(eq(spaceInvites.token, inviteToken))
    .limit(1);

  const row = rows[0];
  if (row && row.status === "pending") {
    invite = { email: row.email, spaceName: row.spaceName };
  }
}
---

<Layout title="Create Account">
  <div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center px-4">
    <div class="w-full max-w-[400px]">
      <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold text-text-primary">Wellrox Video Review</h1>
        {invite ? (
          <p class="mt-2 text-sm text-text-secondary">
            You've been invited to join <span class="font-medium text-text-primary">{invite.spaceName}</span>.
            Set up your account to accept.
          </p>
        ) : (
          <p class="mt-2 text-sm text-text-secondary">
            Create your account with your Wellrox email to start reviewing videos.
          </p>
        )}
      </div>

      <div class="rounded-2xl border border-border-default bg-bg-secondary p-8">
        {error && (
          <div class="mb-4 rounded-lg bg-accent-danger/15 px-4 py-2 text-sm text-accent-danger">
            {error}
          </div>
        )}

        <form method="POST" action="/api/auth/register" class="space-y-4">
          {inviteToken && (
            <input type="hidden" name="inviteToken" value={inviteToken} />
          )}
          <div>
            <label for="displayName" class="mb-1 block text-sm font-medium text-text-secondary">
              Display Name
            </label>
            <input
              type="text"
              id="displayName"
              name="displayName"
              required
              class="w-full rounded-lg border border-border-default bg-bg-input px-4 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent-primary focus:outline-none"
              placeholder="First and last name"
            />
          </div>
          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-text-secondary">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              readonly={invite !== null}
              value={invite?.email ?? ""}
              class={`w-full rounded-lg border border-border-default bg-bg-input px-4 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent-primary focus:outline-none ${invite ? "cursor-not-allowed opacity-70" : ""}`}
              placeholder="you@wellrox.com"
            />
            {!invite && (
              <p class="mt-1 text-xs text-text-tertiary">
                Wellrox Video Review is limited to wellrox.com email addresses. External collaborators must use an invite link.
              </p>
            )}
          </div>
          <div>
            <label for="password" class="mb-1 block text-sm font-medium text-text-secondary">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              class="w-full rounded-lg border border-border-default bg-bg-input px-4 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent-primary focus:outline-none"
              placeholder="At least 8 characters"
            />
          </div>
          <div>
            <label for="confirmPassword" class="mb-1 block text-sm font-medium text-text-secondary">
              Confirm Password
            </label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              required
              minlength="8"
              class="w-full rounded-lg border border-border-default bg-bg-input px-4 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:border-accent-primary focus:outline-none"
              placeholder="Confirm your password"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-accent-primary px-5 py-2.5 text-sm font-medium text-white transition-all duration-150 hover:bg-accent-hover hover:shadow-[0_2px_8px_rgba(108,92,231,0.3)]"
          >
            {invite ? "Accept Invite & Create Account" : "Create Account"}
          </button>
        </form>

        <p class="mt-6 text-center text-sm text-text-tertiary">
          Already have an account?{" "}
          <a href="/login" class="text-accent-primary hover:text-accent-hover">
            Sign In
          </a>
        </p>
      </div>
    </div>
  </div>
</Layout>
