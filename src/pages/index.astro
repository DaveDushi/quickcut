              <div class="rounded-xl border border-border-default bg-white p-4">
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.15em] text-text-tertiary">Cuts in review</p>
                <p class="mt-2 font-display text-[28px] font-bold text-text-primary">12</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
