---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";

const user = Astro.locals.user;
if (user) {
  return Astro.redirect("/dashboard");
}
---

<Layout
  title="Collaborative Video Review"
  description="Wellrox Video Review is collaborative video review built on Cloudflare. Team spaces, member invites, version stacks, timestamped comments, share links for clients, resumable 5GB uploads, and global HLS playback."
>
  <!-- Marketing nav -->
  <header
    id="marketing-nav"
    class="fixed inset-x-0 top-0 z-50 transition-[background-color,backdrop-filter,box-shadow,border-color] duration-300"
  >
    <div class="mx-auto flex h-[76px] max-w-[1200px] items-center px-6 sm:px-8">
      <a href="/" class="flex items-center gap-3">
        <Logo class="h-9 w-auto sm:h-10" />
        <span class="hidden font-display text-base italic text-text-secondary sm:inline">
          Video Review
        </span>
      </a>
      <nav class="ml-12 hidden items-center gap-8 md:flex">
        <a href="#features" class="text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">Features</a>
        <a href="#workflow" class="text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">Workflow</a>
        <a href="#stack" class="text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">Stack</a>
        <a href="#faq" class="text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">FAQ</a>
      </nav>
      <div class="ml-auto flex items-center gap-4">
        <a href="/login" class="hidden text-sm font-medium text-text-secondary transition-colors hover:text-text-primary sm:inline">
          Sign in
        </a>
        <a
          href="/register"
          class="inline-flex items-center justify-center rounded-full bg-accent-primary px-7 py-2.5 text-sm font-semibold text-white shadow-[0_4px_24px_rgba(180,145,143,0.25)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-hover hover:shadow-[0_8px_40px_rgba(180,145,143,0.4)]"
        >
          Get Started
        </a>
      </div>
    </div>
  </header>

  <script is:inline>
    (function () {
      const nav = document.getElementById("marketing-nav");
      if (!nav) return;
      const update = () => {
        if (window.scrollY > 40) {
          nav.classList.add("nav-scrolled");
        } else {
          nav.classList.remove("nav-scrolled");
        }
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
    })();
  </script>

  <style>
    #marketing-nav {
      background-color: transparent;
    }
    #marketing-nav.nav-scrolled {
      background-color: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 1px 12px rgba(180, 145, 143, 0.08);
      border-bottom: 1px solid rgba(224, 218, 218, 0.6);
    }

    .hero-bg {
      background:
        radial-gradient(ellipse at 80% 0%, rgba(196, 184, 176, 0.22), transparent 55%),
        linear-gradient(180deg, #ffffff 0%, #faf8f5 100%);
    }
    .hero-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(168deg, transparent 0%, #f7f3ef 35%, #ede7e0 100%);
      clip-path: polygon(0 30%, 100% 0%, 100% 100%, 0% 100%);
      opacity: 0.55;
      z-index: -1;
    }

    .stacked-rocks {
      opacity: 0.07;
      mix-blend-mode: multiply;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .reveal {
      animation: fadeUp 0.7s ease-out backwards;
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
    }
  </style>

  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden pt-[76px]">
    <!-- Stacked rocks decorative motif -->
    <img
      src="/gray-rocks.png"
      alt=""
      aria-hidden="true"
      class="stacked-rocks pointer-events-none absolute right-[-60px] top-32 -z-10 hidden h-[420px] w-auto md:block lg:right-12 lg:h-[520px]"
    />

    <div class="relative mx-auto max-w-[1200px] px-6 pt-20 pb-28 sm:px-8 sm:pt-28 sm:pb-32">
      <div class="mx-auto max-w-[820px] text-center">
        <div
          class="reveal mb-7 inline-flex items-center gap-2.5 rounded-full border-[1.5px] px-5 py-2 text-[13px] font-semibold uppercase tracking-[0.08em]"
          style="background: rgba(180,145,143,0.12); border-color: rgba(180,145,143,0.18); color: #9a7573;"
        >
          <span class="size-1.5 rounded-full bg-accent-primary"></span>
          Team spaces for collaborative review
        </div>
        <h1
          class="reveal font-display text-[44px] font-bold leading-[1.06] tracking-[-0.025em] text-text-primary sm:text-[64px] lg:text-[72px]"
          style="animation-delay: 0.1s;"
        >
          Review video together.
          <span class="block italic text-accent-primary">Frame by frame.</span>
        </h1>
        <p
          class="reveal mx-auto mt-7 max-w-2xl text-[17px] font-light leading-[1.7] text-text-secondary sm:text-[20px]"
          style="animation-delay: 0.2s;"
        >
          Create spaces for each team or client, invite collaborators, upload up to 5GB, stack new cuts as
          versions, and collect timestamped feedback — no account required for external reviewers.
        </p>
        <div class="reveal mt-11 flex flex-wrap items-center justify-center gap-4" style="animation-delay: 0.3s;">
          <a
            href="/register"
            class="inline-flex items-center justify-center rounded-full bg-accent-primary px-12 py-[18px] text-[17px] font-semibold text-white shadow-[0_4px_24px_rgba(180,145,143,0.25)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-hover hover:shadow-[0_8px_40px_rgba(180,145,143,0.4)]"
          >
            Get Started Free
          </a>
          <a
            href="/login"
            class="inline-flex items-center justify-center rounded-full border-[1.5px] border-border-default bg-white px-10 py-[18px] text-[17px] font-semibold text-text-primary transition-all duration-200 hover:-translate-y-0.5 hover:border-primary-light hover:bg-cream-subtle"
          >
            Sign In
          </a>
        </div>

        <div
          class="reveal mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-[13px] font-medium text-text-secondary"
          style="animation-delay: 0.4s;"
        >
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-accent-secondary"></span>
            Free to start
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-accent-primary"></span>
            5GB resumable uploads
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-taupe"></span>
            Built on Cloudflare
          </span>
        </div>
      </div>

      <!-- Hero mockup: faux video review UI -->
      <div class="reveal mx-auto mt-20 max-w-5xl" style="animation-delay: 0.5s;">
        <div
          class="rounded-[24px] border-[1.5px] border-border-default bg-white p-3 shadow-[0_30px_80px_-20px_rgba(180,145,143,0.35)]"
        >
          <!-- Mock window chrome -->
          <div class="mb-3 flex items-center justify-between px-2 pt-1">
            <div class="flex items-center gap-1.5">
              <span class="size-2.5 rounded-full bg-accent-danger/50"></span>
              <span class="size-2.5 rounded-full bg-accent-warning/50"></span>
              <span class="size-2.5 rounded-full bg-accent-secondary/50"></span>
            </div>
            <div class="flex items-center gap-2">
              <span
                class="rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.06em]"
                style="background: rgba(180,145,143,0.12); color: #9a7573;"
              >
                Acme Launch Space
              </span>
              <span
                class="rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.06em]"
                style="background: rgba(56,161,105,0.1); color: #38a169;"
              >
                Approved
              </span>
            </div>
          </div>

          <!-- Faux video frame -->
          <div class="relative aspect-video overflow-hidden rounded-[16px] bg-cream-dark">
            <div
              class="absolute inset-0"
              style="background: radial-gradient(circle at 30% 40%, rgba(180,145,143,0.18), transparent 55%), radial-gradient(circle at 70% 60%, rgba(196,184,176,0.2), transparent 55%);"
            >
            </div>
            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div
                class="flex size-16 items-center justify-center rounded-full bg-accent-primary shadow-[0_0_50px_rgba(180,145,143,0.55)]"
              >
                <svg viewBox="0 0 24 24" fill="white" class="size-6 translate-x-0.5">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>

            <!-- Floating comment card -->
            <div
              class="absolute top-6 right-6 max-w-[280px] rounded-[16px] border-[1.5px] border-border-default bg-white/95 p-3.5 shadow-[0_12px_32px_rgba(180,145,143,0.2)] backdrop-blur-sm"
            >
              <div class="flex items-start gap-2.5">
                <div
                  class="flex size-8 shrink-0 items-center justify-center rounded-full bg-accent-primary text-xs font-semibold text-white"
                >
                  JQ
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold text-text-primary">James</span>
                    <span class="font-mono text-[11px] font-medium text-accent-primary">0:12</span>
                  </div>
                  <p class="mt-1 text-xs leading-relaxed text-text-secondary">
                    Can we tighten the cut here? Feels a beat too long.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Scrubber with comment markers -->
          <div class="mt-4 px-2 pb-2">
            <div class="relative h-1.5 rounded-full bg-cream-dark">
              <div class="absolute inset-y-0 left-0 w-[35%] rounded-full bg-accent-primary"></div>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-warning"
                style="left: 12%"
              ></span>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-info"
                style="left: 35%"
              ></span>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-primary"
                style="left: 58%"
              ></span>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-secondary"
                style="left: 82%"
              ></span>
            </div>
            <div class="mt-2 flex justify-between font-mono text-[11px] text-text-tertiary">
              <span>0:00</span>
              <span>2:34</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="relative bg-white">
    <div class="mx-auto max-w-[1200px] px-6 py-24 sm:px-8 sm:py-28">
      <div class="mx-auto max-w-2xl text-center">
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[12px] font-semibold uppercase tracking-[0.15em] text-accent-primary"
          style="background: rgba(180,145,143,0.1);"
        >
          Features
        </div>
        <h2 class="font-display text-[32px] font-bold leading-[1.15] tracking-tight text-text-primary sm:text-[44px]">
          Everything you need to ship video, faster
        </h2>
        <p class="mt-5 text-[17px] font-light leading-[1.7] text-text-secondary">
          A focused review workflow without the bloat. Drop in, leave feedback, get out.
        </p>
      </div>

      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Feature 1 -->
        <div class="brand-card p-8">
          <div
            class="mb-5 flex size-14 items-center justify-center rounded-2xl text-accent-primary"
            style="background: rgba(180,145,143,0.1);"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-7">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <path d="M12 12V3"></path>
              <path d="M7 8l5-5 5 5"></path>
            </svg>
          </div>
          <h3 class="text-[20px] font-semibold text-text-primary">Resumable 5GB uploads</h3>
          <p class="mt-3 text-[15px] leading-[1.6] text-text-secondary">
            Drag, drop, walk away. TUS-resumable uploads keep going across reconnects so you never lose progress.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="brand-card p-8">
          <div
            class="mb-5 flex size-14 items-center justify-center rounded-2xl text-accent-primary"
            style="background: rgba(180,145,143,0.1);"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-7">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <h3 class="text-[20px] font-semibold text-text-primary">Timestamped comments</h3>
          <p class="mt-3 text-[15px] leading-[1.6] text-text-secondary">
            Pin feedback to the exact frame. No more "around the 30 second mark…" — reviewers click and comment.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="brand-card p-8">
          <div
            class="mb-5 flex size-14 items-center justify-center rounded-2xl text-accent-primary"
            style="background: rgba(180,145,143,0.1);"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-7">
              <path d="M17 8h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"></path>
              <polyline points="9 12 11 14 15 10"></polyline>
              <path d="M9 4h6v4H9z"></path>
            </svg>
          </div>
          <h3 class="text-[20px] font-semibold text-text-primary">Version stacking</h3>
          <p class="mt-3 text-[15px] leading-[1.6] text-text-secondary">
            Upload new cuts into an ordered stack. Switch versions without mixing comments between edits.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="brand-card p-8">
          <div
            class="mb-5 flex size-14 items-center justify-center rounded-2xl text-accent-primary"
            style="background: rgba(180,145,143,0.1);"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-7">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="text-[20px] font-semibold text-text-primary">Team spaces</h3>
          <p class="mt-3 text-[15px] leading-[1.6] text-text-secondary">
            Separate every client, channel, or project into its own space with members, invites, and settings.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="brand-card p-8">
          <div
            class="mb-5 flex size-14 items-center justify-center rounded-2xl text-accent-primary"
            style="background: rgba(180,145,143,0.1);"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-7">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
          </div>
          <h3 class="text-[20px] font-semibold text-text-primary">Public share links</h3>
          <p class="mt-3 text-[15px] leading-[1.6] text-text-secondary">
            Send a link to a client. They review and comment without an account. Revoke access anytime.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="brand-card p-8">
          <div
            class="mb-5 flex size-14 items-center justify-center rounded-2xl text-accent-primary"
            style="background: rgba(180,145,143,0.1);"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-7">
              <path d="M9 11l3 3L22 4"></path>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
            </svg>
          </div>
          <h3 class="text-[20px] font-semibold text-text-primary">Approval workflows</h3>
          <p class="mt-3 text-[15px] leading-[1.6] text-text-secondary">
            Set required approvals per space so every team has the right sign-off process before a cut ships.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Spaces -->
  <section class="bg-cream">
    <div class="mx-auto grid max-w-[1200px] gap-12 px-6 py-24 sm:px-8 sm:py-28 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[12px] font-semibold uppercase tracking-[0.15em] text-accent-primary"
          style="background: rgba(180,145,143,0.12);"
        >
          New: Spaces
        </div>
        <h2 class="font-display text-[32px] font-bold leading-[1.15] tracking-tight text-text-primary sm:text-[44px]">
          Keep every review group in its own space
        </h2>
        <p class="mt-5 text-[17px] font-light leading-[1.7] text-text-secondary">
          Spaces give each team, client, or project a dedicated home for videos, members, approvals, and invite notifications.
          Switch contexts without mixing feedback, files, or access.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="brand-card p-5">
            <h3 class="text-[15px] font-semibold text-text-primary">Invite teammates</h3>
            <p class="mt-2 text-sm leading-[1.6] text-text-secondary">
              Send space invites by email and let users accept from their notifications page.
            </p>
          </div>
          <div class="brand-card p-5">
            <h3 class="text-[15px] font-semibold text-text-primary">Scope access</h3>
            <p class="mt-2 text-sm leading-[1.6] text-text-secondary">
              Videos, folders, members, and approval settings stay tied to the selected space.
            </p>
          </div>
        </div>
      </div>

      <div
        class="rounded-[24px] border-[1.5px] border-border-default bg-white p-3 shadow-[0_24px_64px_-20px_rgba(180,145,143,0.3)]"
      >
        <div class="rounded-[16px] border border-border-default bg-cream-subtle p-6">
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border-default pb-5">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-text-tertiary">Current space</p>
              <h3 class="mt-1.5 font-display text-[22px] font-semibold text-text-primary">Acme Launch</h3>
            </div>
            <span
              class="rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.06em] text-accent-primary"
              style="background: rgba(180,145,143,0.12);"
            >
              4 members
            </span>
          </div>

          <div class="mt-6 space-y-3">
            <div class="flex items-center justify-between rounded-xl border border-border-default bg-white p-4">
              <div class="flex items-center gap-3">
                <div
                  class="flex size-10 items-center justify-center rounded-xl text-accent-primary"
                  style="background: rgba(180,145,143,0.12);"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-4">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-text-primary">Invite pending</p>
                  <p class="text-xs text-text-tertiary">maya@example.com</p>
                </div>
              </div>
              <span
                class="rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.06em] text-accent-warning"
                style="background: rgba(243,156,18,0.12);"
              >
                Pending
              </span>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-xl border border-border-default bg-white p-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-text-tertiary">Required approvals</p>
                <p class="mt-2 font-display text-[28px] font-bold text-text-primary">2</p>
              </div>
              <div class="rounded-xl border border-border-default bg-white p-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-text-tertiary">Videos in review</p>
                <p class="mt-2 font-display text-[28px] font-bold text-text-primary">12</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Workflow -->
  <section id="workflow" class="bg-white">
    <div class="mx-auto max-w-[1200px] px-6 py-24 sm:px-8 sm:py-28">
      <div class="mx-auto max-w-2xl text-center">
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[12px] font-semibold uppercase tracking-[0.15em] text-accent-primary"
          style="background: rgba(180,145,143,0.1);"
        >
          Workflow
        </div>
        <h2 class="font-display text-[32px] font-bold leading-[1.15] tracking-tight text-text-primary sm:text-[44px]">
          From upload to approval in three steps
        </h2>
        <p class="mt-5 text-[17px] font-light leading-[1.7] text-text-secondary">
          A workflow designed for editors and the people who review their work.
        </p>
      </div>

      <div class="mt-16 grid gap-8 lg:grid-cols-3 lg:gap-10">
        <!-- Step 1: Upload -->
        <div class="brand-card p-8">
          <div class="flex items-center gap-4">
            <span
              class="flex size-16 shrink-0 items-center justify-center rounded-full border-[2px] border-primary-light bg-white font-display text-[24px] font-bold text-accent-primary transition-all duration-300 hover:bg-accent-primary hover:text-white"
            >
              1
            </span>
            <h3 class="text-[20px] font-semibold text-text-primary">Upload</h3>
          </div>
          <p class="mt-5 text-[15px] leading-[1.6] text-text-secondary">
