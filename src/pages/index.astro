---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";

const user = Astro.locals.user;
if (user) {
  return Astro.redirect("/dashboard");
}

const quickActions = [
  {
    code: "01",
    title: "Upload a cut",
    hint: "Drag in MP4/MOV up to 5GB. Resumable.",
    href: "/upload",
    icon: "upload",
  },
  {
    code: "02",
    title: "Browse your spaces",
    hint: "Jump back into the team or client space.",
    href: "/dashboard",
    icon: "spaces",
  },
  {
    code: "03",
    title: "Check pending invites",
    hint: "Accept invites someone sent you.",
    href: "/notifications",
    icon: "bell",
  },
  {
    code: "04",
    title: "Send a client a share link",
    hint: "Open a video → Share. No account needed.",
    href: "/dashboard",
    icon: "link",
  },
  {
    code: "05",
    title: "Invite a teammate",
    hint: "Open a space → Settings → Members.",
    href: "/dashboard",
    icon: "people",
  },
  {
    code: "06",
    title: "Set required approvals",
    hint: "Open space settings → Approvals.",
    href: "/dashboard",
    icon: "check",
  },
];
---

<Layout
  title="Wellrox Video Review"
  description="Internal video review for Wellrox teams. Upload cuts, leave timestamped notes, ship the edit."
>
  <!-- Launchpad nav -->
  <header
    id="marketing-nav"
    class="fixed inset-x-0 top-0 z-50 transition-[background-color,backdrop-filter,box-shadow,border-color] duration-300"
  >
    <div class="mx-auto flex h-[76px] max-w-[1200px] items-center px-6 sm:px-8">
      <a href="/" class="flex items-center gap-3">
        <Logo class="h-9 w-auto sm:h-10" />
        <span
          class="hidden items-center gap-2 sm:flex"
        >
          <span class="font-display text-base italic text-text-secondary">Video Review</span>
          <span
            class="rounded-full border border-border-default px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-text-tertiary"
          >
            Internal
          </span>
        </span>
      </a>
      <div class="ml-auto flex items-center gap-3 sm:gap-4">
        <a
          href="/login"
          class="text-sm font-medium text-text-secondary transition-colors hover:text-text-primary"
        >
          Sign in
        </a>
        <a
          href="/register"
          class="inline-flex items-center justify-center rounded-full bg-accent-primary px-5 py-2.5 text-sm font-semibold text-white shadow-[0_4px_24px_rgba(180,145,143,0.25)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-hover hover:shadow-[0_8px_40px_rgba(180,145,143,0.4)] sm:px-7"
        >
          Create account
        </a>
      </div>
    </div>
  </header>

  <script is:inline>
    (function () {
      const nav = document.getElementById("marketing-nav");
      if (!nav) return;
      const update = () => {
        if (window.scrollY > 40) {
          nav.classList.add("nav-scrolled");
        } else {
          nav.classList.remove("nav-scrolled");
        }
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
    })();
  </script>

  <style>
    #marketing-nav {
      background-color: transparent;
    }
    #marketing-nav.nav-scrolled {
      background-color: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 1px 12px rgba(180, 145, 143, 0.08);
      border-bottom: 1px solid rgba(224, 218, 218, 0.6);
    }

    .hero-bg {
      background:
        radial-gradient(ellipse at 80% 0%, rgba(196, 184, 176, 0.22), transparent 55%),
        linear-gradient(180deg, #ffffff 0%, #faf8f5 100%);
    }
    .hero-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(168deg, transparent 0%, #f7f3ef 35%, #ede7e0 100%);
      clip-path: polygon(0 30%, 100% 0%, 100% 100%, 0% 100%);
      opacity: 0.55;
      z-index: -1;
    }

    .stacked-rocks {
      opacity: 0.06;
      mix-blend-mode: multiply;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .reveal { animation: fadeUp 0.7s ease-out backwards; }

    @keyframes recPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.35; }
    }
    .rec-dot { animation: recPulse 1.6s ease-in-out infinite; }

    @media (prefers-reduced-motion: reduce) {
      .reveal, .rec-dot {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
    }

    .grain-card {
      position: relative;
    }
    .grain-card::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      pointer-events: none;
      background-image: radial-gradient(rgba(180, 145, 143, 0.06) 1px, transparent 1px);
      background-size: 14px 14px;
      opacity: 0.5;
      mix-blend-mode: multiply;
    }
  </style>

  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden pt-[76px]">
    <img
      src="/gray-rocks.png"
      alt=""
      aria-hidden="true"
      class="stacked-rocks pointer-events-none absolute right-[-60px] top-32 -z-10 hidden h-[420px] w-auto md:block lg:right-12 lg:h-[520px]"
    />

    <div class="relative mx-auto max-w-[1200px] px-6 pt-16 pb-24 sm:px-8 sm:pt-24 sm:pb-28">
      <div class="mx-auto max-w-[820px] text-center">
        <div
          class="reveal mb-7 inline-flex items-center gap-2.5 rounded-full border-[1.5px] px-4 py-1.5 font-mono text-[12px] font-semibold uppercase tracking-[0.12em]"
          style="background: rgba(229,62,62,0.06); border-color: rgba(229,62,62,0.18); color: #c44848;"
        >
          <span class="rec-dot inline-flex size-2 rounded-full bg-accent-danger"></span>
          REC · 00:00 · Internal
        </div>
        <h1
          class="reveal font-display text-[44px] font-bold leading-[1.06] tracking-[-0.025em] text-text-primary sm:text-[64px] lg:text-[72px]"
          style="animation-delay: 0.1s;"
        >
          The Wellrox
          <span class="block italic text-accent-primary">cutting room.</span>
        </h1>
        <p
          class="reveal mx-auto mt-7 max-w-2xl text-[17px] font-light leading-[1.7] text-text-secondary sm:text-[20px]"
          style="animation-delay: 0.2s;"
        >
          Upload cuts, leave timestamped notes, ship the edit. An in-house review tool for the Wellrox team.
        </p>
        <div class="reveal mt-11 flex flex-wrap items-center justify-center gap-4" style="animation-delay: 0.3s;">
          <a
            href="/login"
            class="inline-flex items-center justify-center rounded-full bg-accent-primary px-12 py-[18px] text-[17px] font-semibold text-white shadow-[0_4px_24px_rgba(180,145,143,0.25)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-hover hover:shadow-[0_8px_40px_rgba(180,145,143,0.4)]"
          >
            Sign in
          </a>
          <a
            href="/register"
            class="inline-flex items-center justify-center rounded-full border-[1.5px] border-border-default bg-white px-10 py-[18px] text-[17px] font-semibold text-text-primary transition-all duration-200 hover:-translate-y-0.5 hover:border-primary-light hover:bg-cream-subtle"
          >
            Wellrox staff? Create account
          </a>
        </div>
        <details
          id="invite-paste"
          class="reveal mt-6 inline-block text-left"
          style="animation-delay: 0.35s;"
        >
          <summary
            class="invite-summary inline-flex cursor-pointer list-none items-center gap-2 rounded-full border-[1.5px] border-border-default bg-white/70 px-5 py-2 text-[13px] font-medium text-text-secondary transition-all duration-200 hover:-translate-y-0.5 hover:border-primary-light hover:bg-white hover:text-text-primary"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-3.5 text-accent-primary" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
            </svg>
            <span>Got an invite link? Open it</span>
            <span class="invite-chevron font-mono text-text-tertiary transition-transform duration-200" aria-hidden="true">›</span>
          </summary>
          <form
            id="invite-form"
            class="mt-3 flex flex-col items-stretch gap-2 rounded-2xl border-[1.5px] border-border-default bg-white p-2 shadow-[0_8px_28px_-12px_rgba(180,145,143,0.25)] sm:flex-row sm:items-center"
          >
            <label for="invite-input" class="sr-only">Invite link or token</label>
            <input
              id="invite-input"
              type="text"
              required
              autocomplete="off"
              spellcheck="false"
              placeholder="Paste invite link or token"
              class="min-w-0 flex-1 rounded-xl border border-transparent bg-cream-subtle px-4 py-2.5 font-mono text-[13px] text-text-primary placeholder:text-text-tertiary focus:border-primary-light focus:bg-white focus:outline-none"
            />
            <button
              type="submit"
              class="inline-flex shrink-0 items-center justify-center gap-1.5 rounded-xl bg-accent-primary px-5 py-2.5 text-[13px] font-semibold text-white transition-all duration-200 hover:bg-accent-hover"
            >
              Open invite
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" class="size-3.5" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </form>
          <p id="invite-error" class="mt-2 hidden font-mono text-[11px] text-accent-danger" role="alert"></p>
        </details>

        <script is:inline>
          (function () {
            const details = document.getElementById("invite-paste");
            const form = document.getElementById("invite-form");
            const input = document.getElementById("invite-input");
            const error = document.getElementById("invite-error");
            const chevron = details && details.querySelector(".invite-chevron");
            if (!details || !form || !input || !error) return;

            details.addEventListener("toggle", () => {
              if (chevron) chevron.style.transform = details.open ? "rotate(90deg)" : "rotate(0deg)";
              if (details.open) setTimeout(() => input.focus(), 50);
              else { error.classList.add("hidden"); error.textContent = ""; }
            });

            const showError = (msg) => { error.textContent = msg; error.classList.remove("hidden"); };

            form.addEventListener("submit", (e) => {
              e.preventDefault();
              const raw = input.value.trim();
              if (!raw) return;
              let token = raw;
              const match = raw.match(/\/invites\/([A-Za-z0-9_-]+)/);
              if (match) token = match[1];
              else if (/^https?:\/\//i.test(raw)) {
                showError("That doesn't look like an invite link.");
                return;
              }
              if (!/^[A-Za-z0-9_-]+$/.test(token)) {
                showError("Invite token can only contain letters, numbers, - and _.");
                return;
              }
              window.location.href = "/invites/" + encodeURIComponent(token);
            });
          })();
        </script>

        <div
          class="reveal mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 font-mono text-[12px] text-text-tertiary"
          style="animation-delay: 0.4s;"
        >
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-accent-secondary"></span>
            5GB resumable uploads
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-accent-primary"></span>
            Timestamped comments
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-taupe"></span>
            Version stacks per video
          </span>
        </div>
      </div>

      <!-- Hero mockup: faux video review UI -->
      <div class="reveal mx-auto mt-20 max-w-5xl" style="animation-delay: 0.5s;">
        <div
          class="rounded-[24px] border-[1.5px] border-border-default bg-white p-3 shadow-[0_30px_80px_-20px_rgba(180,145,143,0.35)]"
        >
          <!-- Mock window chrome -->
          <div class="mb-3 flex items-center justify-between px-2 pt-1">
            <div class="flex items-center gap-1.5">
              <span class="size-2.5 rounded-full bg-accent-danger/50"></span>
              <span class="size-2.5 rounded-full bg-accent-warning/50"></span>
              <span class="size-2.5 rounded-full bg-accent-secondary/50"></span>
            </div>
            <div class="flex items-center gap-2">
              <span
                class="rounded-full px-3 py-1 font-mono text-[11px] font-semibold uppercase tracking-[0.06em]"
                style="background: rgba(180,145,143,0.12); color: #9a7573;"
              >
                Wellrox · Spring Drop
              </span>
              <span
                class="hidden rounded-full px-3 py-1 font-mono text-[11px] font-semibold uppercase tracking-[0.06em] sm:inline"
                style="background: rgba(56,161,105,0.1); color: #38a169;"
              >
                v3 · 2/3 approved
              </span>
            </div>
          </div>

          <!-- Faux video frame -->
          <div class="relative aspect-video overflow-hidden rounded-[16px] bg-cream-dark">
            <div
              class="absolute inset-0"
              style="background: radial-gradient(circle at 30% 40%, rgba(180,145,143,0.18), transparent 55%), radial-gradient(circle at 70% 60%, rgba(196,184,176,0.2), transparent 55%);"
            ></div>
            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div
                class="flex size-16 items-center justify-center rounded-full bg-accent-primary shadow-[0_0_50px_rgba(180,145,143,0.55)]"
              >
                <svg viewBox="0 0 24 24" fill="white" class="size-6 translate-x-0.5">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>

            <!-- Timecode overlay -->
            <div
              class="absolute bottom-4 left-4 rounded-md bg-black/55 px-2.5 py-1 font-mono text-[11px] font-semibold tracking-wider text-white/95"
            >
              00:42 / 02:34
            </div>

            <!-- Floating comment card -->
            <div
              class="absolute top-6 right-6 max-w-[280px] rounded-[16px] border-[1.5px] border-border-default bg-white/95 p-3.5 shadow-[0_12px_32px_rgba(180,145,143,0.2)] backdrop-blur-sm"
            >
              <div class="flex items-start gap-2.5">
                <div
                  class="flex size-8 shrink-0 items-center justify-center rounded-full bg-accent-primary text-xs font-semibold text-white"
                >
                  MK
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-semibold text-text-primary">Maya</span>
                    <span class="font-mono text-[11px] font-medium text-accent-primary">0:42</span>
                  </div>
                  <p class="mt-1 text-xs leading-relaxed text-text-secondary">
                    Tighten this beat — drop the breath before the cut.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Scrubber with comment markers -->
          <div class="mt-4 px-2 pb-2">
            <div class="relative h-1.5 rounded-full bg-cream-dark">
              <div class="absolute inset-y-0 left-0 w-[35%] rounded-full bg-accent-primary"></div>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-warning"
                style="left: 12%"
              ></span>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-info"
                style="left: 35%"
              ></span>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-primary"
                style="left: 58%"
              ></span>
              <span
                class="absolute top-1/2 size-3 -translate-y-1/2 rounded-full border-2 border-white bg-accent-secondary"
                style="left: 82%"
              ></span>
            </div>
            <div class="mt-2 flex justify-between font-mono text-[11px] text-text-tertiary">
              <span>00:00</span>
              <span>02:34</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick actions -->
  <section id="actions" class="relative bg-white">
    <div class="mx-auto max-w-[1200px] px-6 py-24 sm:px-8 sm:py-28">
      <div class="mx-auto max-w-2xl text-center">
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-primary"
          style="background: rgba(180,145,143,0.1);"
        >
          // jump in
        </div>
        <h2 class="font-display text-[32px] font-bold leading-[1.15] tracking-tight text-text-primary sm:text-[44px]">
          Skip the menu. Pick a verb.
        </h2>
        <p class="mt-5 text-[17px] font-light leading-[1.7] text-text-secondary">
          Six things you'll actually do here. Sign in first — then come back, or just bookmark the action you reach for the most.
        </p>
      </div>

      <ul class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {quickActions.map((action) => (
          <li>
            <a
              href={action.href}
              class="brand-card group flex h-full flex-col p-7 transition-all duration-200"
            >
              <div class="flex items-center justify-between">
                <div
                  class="flex size-12 items-center justify-center rounded-2xl text-accent-primary"
                  style="background: rgba(180,145,143,0.1);"
                >
                  {action.icon === "upload" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="17 8 12 3 7 8"></polyline>
                      <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                  )}
                  {action.icon === "spaces" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6">
                      <rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
                      <rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
                      <rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
                      <rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
                    </svg>
                  )}
                  {action.icon === "bell" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6">
                      <path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                      <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                    </svg>
                  )}
                  {action.icon === "link" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6">
                      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                    </svg>
                  )}
                  {action.icon === "people" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6">
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                      <circle cx="9" cy="7" r="4"></circle>
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                      <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                  )}
                  {action.icon === "check" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="size-6">
                      <path d="M9 11l3 3L22 4"></path>
                      <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                    </svg>
                  )}
                </div>
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.18em] text-text-tertiary">
                  {action.code}
                </span>
              </div>
              <h3 class="mt-6 text-[19px] font-semibold text-text-primary">
                {action.title}
              </h3>
              <p class="mt-2 flex-1 text-[14px] leading-[1.6] text-text-secondary">
                {action.hint}
              </p>
              <div class="mt-6 flex items-center gap-2 font-mono text-[12px] font-semibold uppercase tracking-[0.12em] text-accent-primary">
                <span>Open</span>
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="size-4 transition-transform duration-200 group-hover:translate-x-1"
                >
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Spaces in 30 seconds -->
  <section class="bg-cream">
    <div class="mx-auto grid max-w-[1200px] gap-12 px-6 py-24 sm:px-8 sm:py-28 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-primary"
          style="background: rgba(180,145,143,0.12);"
        >
          // 00:30 refresher
        </div>
        <h2 class="font-display text-[32px] font-bold leading-[1.15] tracking-tight text-text-primary sm:text-[44px]">
          Spaces in 30 seconds
        </h2>
        <p class="mt-5 text-[17px] font-light leading-[1.7] text-text-secondary">
          Each team or client gets a Space. Members, videos, approvals, and invites are scoped to one space at a time —
          so the marketing team's roughs never end up in front of the client.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="brand-card p-5">
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-text-tertiary">members</p>
            <h3 class="mt-2 text-[15px] font-semibold text-text-primary">Invite teammates</h3>
            <p class="mt-2 text-sm leading-[1.6] text-text-secondary">
              Send space invites by email. Pending invites show in the recipient's notifications.
            </p>
          </div>
          <div class="brand-card p-5">
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-text-tertiary">access</p>
            <h3 class="mt-2 text-[15px] font-semibold text-text-primary">Scope everything</h3>
            <p class="mt-2 text-sm leading-[1.6] text-text-secondary">
