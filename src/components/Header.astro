---
import { UserMenu } from "./UserMenu";
import Logo from "./Logo.astro";

interface Props {
  user?: { id: string; email: string; displayName: string } | null;
  backLink?: { href: string; label: string };
}

const { user, backLink } = Astro.props;
---

<header
  class="sticky top-0 z-50 flex h-16 items-center border-b border-border-default bg-white/95 px-6 backdrop-blur-md sm:px-8"
>
  <a href="/dashboard" class="flex items-center gap-3">
    <Logo class="h-8 w-auto" />
    <span class="hidden font-display text-base italic text-text-secondary sm:inline">Video Review</span>
  </a>

  {backLink && (
    <a href={backLink.href} class="ml-6 text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">
      {backLink.label}
    </a>
  )}

  {user && (
    <div class="ml-auto flex items-center">
      <UserMenu client:load displayName={user.displayName} email={user.email} />
    </div>
  )}
</header>
